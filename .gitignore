# Ignore local node modules and build artifacts
/node_modules/
/frontend/node_modules/
/backend/node_modules/

# Ignore environment files
/.env
/backend/.env
/frontend/.env

# Ignore generated Prisma client
/backend/generated/

# Ignore root package artifacts if created unintentionally
/package.json
/package-lock.json

# Ignore VS Code and editor files
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store
Thumbs.db
